# ── Database ─────────────────────────────────────────────────────
DB_USER=trialscope
DB_PASS=changeme_strong_password
DATABASE_URL=postgresql://trialscope:changeme_strong_password@postgres:5432/trialscope

# ── Airflow ───────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here

# ── External APIs ─────────────────────────────────────────────────
# PubMed: free key from https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=your_pubmed_api_key_here

# ClinicalTrials.gov: no key needed, but set a descriptive user agent
CLINICALTRIALS_USER_AGENT=TrialScope-Research/1.0 (your@email.com)

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_PASS=changeme_neo4j_password

# ── MLflow ───────────────────────────────────────────────────────
MLFLOW_EXPERIMENT_NAME=trialscope-outcomes
